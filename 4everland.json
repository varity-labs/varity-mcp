{
  "name": "varity-mcp",
  "type": "container",
  "image": "ghcr.io/varity-labs/varity-mcp:latest",
  "port": 3100,
  "healthCheck": {
    "path": "/health",
    "interval": 30,
    "timeout": 3,
    "retries": 3
  },
  "env": {
    "NODE_ENV": "production",
    "VARITY_AUTH_URL": "https://auth.varity.so",
    "VARITY_GATEWAY_URL": "https://varity.app"
  },
  "domains": [
    "mcp.varity.so"
  ],
  "resources": {
    "cpu": "0.5",
    "memory": "512Mi",
    "storage": "1Gi"
  },
  "scaling": {
    "min": 1,
    "max": 3,
    "targetCPU": 80
  }
}
